{
  "_comment_admin_listen": "客户端管理 API 默认仅本机访问；GUI 通过 127.0.0.1 即可。",
  "mode": "client",
  "client": {
    "admin_listen": "127.0.0.1:9091",
    "enable_pprof": false,
    "tun": {
      "name": "tun0",
      "mtu": 1400,
      "dns_v4": "1.1.1.1",
      "dns_v6": "2606:4700:4700::1111"
    },
    "bypass": {
      "enable": true,
      "server_addr": ""
    },
    "tls": {
      "server_name": "proxy.example.com",
      "_comment_trust_anchor": "信任锚优先级: server_ca_file > use_mozilla_ca > use_system_cas. 企业内网部署推荐 server_ca_file 指向 certsrv 签发的 ca.crt.",
      "server_ca_file": "/etc/connect-ip-tunnel/certs/ca.crt",
      "client_cert_file": "/etc/connect-ip-tunnel/certs/client.crt",
      "client_key_file": "/etc/connect-ip-tunnel/certs/client.key",
      "enable_pqc": true,
      "use_system_cas": false,
      "use_mozilla_ca": false,
      "enable_ech": true,
      "ech_domain": "proxy.example.com",
      "ech_doh_server": "https://cloudflare-dns.com/dns-query",
      "enable_session_cache": true,
      "session_cache_size": 128
    },
    "http3": {
      "udp_recv_buffer": 16777216,
      "udp_send_buffer": 16777216,
      "enable_gso": true,
      "enable_datagrams": true,
      "max_idle_timeout": "30s",
      "keep_alive_period": "10s",
      "allow_0rtt": false,
      "disable_path_mtu_probe": false,
      "initial_stream_window": 16777216,
      "max_stream_window": 67108864,
      "initial_conn_window": 33554432,
      "max_conn_window": 134217728,
      "obfs": {
        "type": "salamander",
        "password": "your-shared-secret"
      },
      "congestion": {
        "algorithm": "bbr2"
      }
    },
    "connect_ip": {
      "addr": "proxy.example.com:443",
      "uri": "/.well-known/masque/ip",
      "authority": "proxy.example.com",
      "wait_for_address_assign": true,
      "address_assign_timeout": "30s",
      "enable_reconnect": true,
      "max_reconnect_delay": "30s",
      "num_sessions": 4
    }
  }
}