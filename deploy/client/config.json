{
  "mode": "client",
  "client": {
    "tun": {
      "name": "tun0",
      "mtu": 1420
    },
    "tls": {
      "server_name":        "server.connect-ip.local",
      "insecure_skip_verify": false,
      "client_cert_file":   "/etc/connect-ip-tunnel/certs/client.crt",
      "client_key_file":    "/etc/connect-ip-tunnel/certs/client.key",
      "enable_pqc":         true,
      "enable_session_cache": true,
      "session_cache_size":   128
    },
    "http3": {
      "enable_datagrams":  true,
      "max_idle_timeout":  "30s",
      "keep_alive_period": "10s"
    },
    "connect_ip": {
      "addr":                  "server:443",
      "uri":                   "/.well-known/masque/ip",
      "authority":             "server.connect-ip.local",
      "enable_reconnect":      true,
      "max_reconnect_delay":   "30s"
    }
  }
}
